{
    "name": "teksite/laravel-filemanager",
    "description": "A simple package for managing files with different drivers.",
    "type": "library",
    "keywords": [
        "laravel",
        "file manager",
        "media manager"
    ],
    "authors": [
        {
            "name": "Sina Zangiband",
            "email": "sina.zangiband@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Teksite\\FileManager\\": "src/"
        }
    },
    "require": {
        "laravel/framework": "^11|^12|^13"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Teksite\\FileManager\\FileManagerServiceProvider"
            ]
        }
    }
}
